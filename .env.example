# Database
DATABASE_URL=postgresql://user:password@db_host:5432/sangam_talks

# YouTube
YOUTUBE_API_KEY=your_youtube_api_key_here

# Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Social Media
X_API_KEY=your_x_api_key_here
X_API_SECRET=your_x_api_secret_here
X_ACCESS_TOKEN=your_x_access_token_here
X_ACCESS_SECRET=your_x_access_secret_here

LINKEDIN_ACCESS_TOKEN=your_linkedin_token_here
LINKEDIN_PERSON_URN=your_linkedin_person_urn_here
LINKEDIN_ORGANIZATION_URN=your_linkedin_org_urn_here

FACEBOOK_PAGE_ID=your_facebook_page_id_here
FACEBOOK_ACCESS_TOKEN=your_facebook_access_token_here

INSTAGRAM_ACCOUNT_ID=your_instagram_account_id_here
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here

# Alerts
TELEGRAM_BOT_TOKEN=optional_telegram_bot_token
TELEGRAM_CHAT_ID=optional_telegram_chat_id

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO
